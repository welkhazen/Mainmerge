# ── Twilio Verify ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Security secrets (must be random and long) ─────────────────
SESSION_SECRET=replace-with-a-random-32-plus-character-secret
PHONE_HMAC_KEY=replace-with-a-different-random-32-plus-character-secret
AUTH_PASSWORD_PEPPER=replace-with-a-random-16-plus-character-pepper
BCRYPT_ROUNDS=12

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=8787
CORS_ORIGIN=http://localhost:8080

# ── Frontend ───────────────────────────────────────────────────
# Leave blank in local dev to use the Vite proxy (/api).
VITE_API_BASE_URL=
# ── Supabase ───────────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── PostHog ────────────────────────────────────────────────────
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=your_posthog_key_here
