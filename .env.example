# ── Twilio Verify ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Security secrets (must be random and long) ─────────────────
SESSION_SECRET=replace-with-a-random-32-plus-character-secret
PHONE_HMAC_KEY=replace-with-a-different-random-32-plus-character-secret
AUTH_PASSWORD_PEPPER=replace-with-a-random-16-plus-character-pepper
BCRYPT_ROUNDS=12

# ── Server ─────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=8787
CORS_ORIGIN=http://localhost:8080

# ── Frontend ───────────────────────────────────────────────────
# Leave blank in local dev to use the Vite proxy (/api).
VITE_API_BASE_URL=